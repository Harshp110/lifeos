{
  "name": "lifeos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev:web": "pnpm --filter @lifeos/web dev",
    "build": "pnpm --filter @lifeos/web build",
    "lint": "pnpm --filter @lifeos/web lint",
    "typecheck": "pnpm --filter @lifeos/web typecheck && pnpm --filter './packages/*' typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5.9.2"
  }
}
