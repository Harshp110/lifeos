# Runtime environment: development, test, or production.
LIFEOS_ENV=development

# FastAPI bind host for local development.
LIFEOS_API_HOST=127.0.0.1

# FastAPI bind port for local development.
LIFEOS_API_PORT=8000

# Comma-separated browser origins allowed to call the API.
LIFEOS_CORS_ORIGINS=http://localhost:3000

# PostgreSQL connection string used by SQLAlchemy and Alembic.
LIFEOS_DATABASE_URL=postgresql+psycopg://lifeos:lifeos@localhost:5432/lifeos

# Redis connection string used by backend infrastructure and future workers.
LIFEOS_REDIS_URL=redis://localhost:6379/0

# Python logging level.
LIFEOS_LOG_LEVEL=INFO

# Public API URL consumed by the Next.js app.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Docker Compose PostgreSQL database name.
POSTGRES_DB=lifeos

# Docker Compose PostgreSQL user.
POSTGRES_USER=lifeos

# Docker Compose PostgreSQL password.
POSTGRES_PASSWORD=lifeos

# Host port exposed by the PostgreSQL container.
POSTGRES_PORT=5432

# Host port exposed by the Redis container.
REDIS_PORT=6379
LIFEOS_SECRET_KEY=CHANGE_ME
LIFEOS_ALGORITHM=HS256
LIFEOS_ACCESS_TOKEN_EXPIRE_MINUTES=30
LIFEOS_REFRESH_TOKEN_EXPIRE_DAYS=30